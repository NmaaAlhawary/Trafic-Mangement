{
  "stream_id": "PHASE1-CAM-05",
  "source_video": "sense05.mov",
  "stream_url": "http://127.0.0.1:8010/video_feed",
  "stats_url": "http://127.0.0.1:8010/stats",
  "dashboard_url": "http://127.0.0.1:8010/",
  "rtsp_simulation": {
    "method": "MJPEG-over-HTTP (YOLO live wrapper)",
    "equivalent_protocol": "RTSP/H.264",
    "codec_assumption": "H.264 / H.265",
    "note": "http_stream.py runs YOLO on each looped video frame, draws detections, and serves multipart/x-mixed-replace for the frontend."
  },
  "frame_spec": {
    "width_px": 1280,
    "height_px": 720,
    "color_space": "RGB",
    "playback_fps": 10,
    "ai_ingestion_fps_range": [
      5,
      15
    ]
  },
  "camera": {
    "camera_id": "WTS CAM 05",
    "site": "INT-001",
    "location": {
      "x": 0,
      "y": -65,
      "height_m": 12.5
    },
    "field_of_view_deg": 78,
    "mounting": "overhead-intersection"
  },
  "serve_command": "../.venv/bin/python src/http_stream.py --video ../../CityFlow/data/wts_videos/sense05.mov --port 8010 --camera-id 'CAM-01 NORTH' --width 1280 --height 720 --fps 10"
}
